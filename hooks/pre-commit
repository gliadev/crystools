#!/usr/bin/env bash

PLUGIN_JSON=".claude-plugin/plugin.json"

if [ ! -f "$PLUGIN_JSON" ]; then
  exit 0
fi

CURRENT=$(grep '"version"' "$PLUGIN_JSON" | sed 's/.*: *"\(.*\)".*/\1/')
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"

echo ""
echo "  Current version: $CURRENT"
echo "  (1) patch → $MAJOR.$MINOR.$((PATCH + 1))"
echo "  (2) minor → $MAJOR.$((MINOR + 1)).0"
echo "  (3) major → $((MAJOR + 1)).0.0"
echo "  (s) skip"
echo ""

exec < /dev/tty
read -rp "  Bump? " choice
exec <&-

case "$choice" in
  1) NEW="$MAJOR.$MINOR.$((PATCH + 1))" ;;
  2) NEW="$MAJOR.$((MINOR + 1)).0" ;;
  3) NEW="$((MAJOR + 1)).0.0" ;;
  s|S|"") exit 0 ;;
  *) echo "  Invalid choice, skipping."; exit 0 ;;
esac

sed -i "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW\"/" "$PLUGIN_JSON"
git add "$PLUGIN_JSON"

# Bump version in all SKILL.md metadata
for SKILL in skills/*/SKILL.md; do
  if [ -f "$SKILL" ] && grep -q "version: $CURRENT" "$SKILL"; then
    sed -i "s/version: $CURRENT/version: $NEW/" "$SKILL"
    git add "$SKILL"
  fi
done

echo "  Bumped: $CURRENT → $NEW"
echo ""
